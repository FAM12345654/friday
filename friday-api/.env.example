FRIDAY_API_HOST=127.0.0.1
FRIDAY_API_PORT=8000
FRIDAY_CORS_ORIGINS=http://localhost:19006,http://localhost:3000,http://127.0.0.1:3000
# Required before binding to LAN/public interfaces or using a tunnel.
FRIDAY_API_TOKEN=
