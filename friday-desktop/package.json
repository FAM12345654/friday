{
  "name": "friday-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.phili.friday",
    "productName": "Friday",
    "files": [
      "main.js",
      "index.html",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "portable"
      ]
    }
  }
}
