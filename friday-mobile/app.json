{
  "expo": {
    "name": "Friday",
    "slug": "friday-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "friday",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#f6f1e4",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "runtimeVersion": "1.0.0-sdk54",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/72728242-5f76-4994-9d19-1033b0db7fe6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phili.friday"
    },
    "android": {
      "package": "com.phili.friday",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#536a48"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM"
      ]
    },
    "extra": {
      "fridayApiUrls": [
        "https://pc.tail4c6152.ts.net"
      ],
      "fridayApiDefaultUrl": "https://pc.tail4c6152.ts.net",
      "eas": {
        "projectId": "72728242-5f76-4994-9d19-1033b0db7fe6"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false
          }
        }
      ],
      "expo-font",
      "expo-sqlite",
      [
        "expo-av",
        {
          "microphonePermission": "Friday nutzt das Mikrofon für Push-to-Talk Sprachbefehle."
        }
      ]
    ]
  }
}
