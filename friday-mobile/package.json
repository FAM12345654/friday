{
  "name": "friday-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas:login": "npx eas-cli@latest login",
    "eas:whoami": "npx eas-cli@latest whoami",
    "eas:configure": "npx eas-cli@latest update:configure",
    "release:check": "powershell -ExecutionPolicy Bypass -NoProfile -File ..\\verify_friday_mobile_release.ps1",
    "live:preview": "powershell -ExecutionPolicy Bypass -NoProfile -File ..\\go_live_friday_mobile.ps1 -Channel preview -NoPause",
    "live:preview:build": "powershell -ExecutionPolicy Bypass -NoProfile -File ..\\go_live_friday_mobile.ps1 -Channel preview -BuildAndroid -NoPause",
    "build:android:preview": "npx eas-cli@latest build --platform android --profile preview",
    "build:android:sdk54": "npx eas-cli@latest build --platform android --profile preview",
    "build:android:production": "npx eas-cli@latest build --platform android --profile production",
    "build:ios:preview": "npx eas-cli@latest build --platform ios --profile preview",
    "build:ios:production": "npx eas-cli@latest build --platform ios --profile production",
    "update:preview": "npx eas-cli@latest update --channel preview --message \"Friday preview update\"",
    "update:production": "npx eas-cli@latest update --channel production --message \"Friday production update\"",
    "test:morning": "node --test tests/morningBriefingPolicy.test.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/figtree": "^0.4.1",
    "expo": "~54.0.35",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-notifications": "~0.32.17",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.18",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.1.10"
  }
}
